generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model User {
  id          String     @id @default(cuid())
  phone       String     @unique
  name        String?
  plateNumber String?
  plateColor  String?    // BLUE / YELLOW / GREEN
  idNumber    String?    // 证件号码，同步给粤运
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  members     Member[]
  orders      Order[]
  vehicles    Vehicle[]
}

model Vehicle {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  plateNumber String
  plateColor  String   // BLUE / YELLOW / GREEN
  isPrimary   Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([userId])
}

model MemberProduct {
  id                 String        @id @default(cuid())
  name               String
  type               String        // YEARLY / MONTHLY / PER_USE
  price              Float
  description        String?
  effectiveStartTime DateTime?     // 生效起始时间
  isActive           Boolean       @default(true)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  orders             Order[]
  members            Member[]
  rights             ProductRight[]
}

model Right {
  id          String         @id @default(cuid())
  name        String
  description String?
  totalLimit  Int?           // 总量控制，null表示不限制
  currentTotal Int           @default(0) // 已发放总量
  detailHtml  String?        // 权益详情展示HTML
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  products    ProductRight[]
  userRights  UserRight[]
}

model ProductRight {
  productId String
  rightId   String
  product   MemberProduct @relation(fields: [productId], references: [id])
  right     Right         @relation(fields: [rightId], references: [id])

  @@id([productId, rightId])
}

model Order {
  id                String    @id @default(cuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id])
  productId         String
  product           MemberProduct @relation(fields: [productId], references: [id])
  amount            Float
  status            String    @default("PENDING") // PENDING(待签约) / PENDING_ACTIVATION(已签约待激活) / PAID(已激活) / CANCELLED / REFUNDED
  payMethod         String?   // WECHAT / ALIPAY / UNIONPAY
  channel           String?   // 签约渠道：WECHAT / ALIPAY / UNIONPAY
  isSigned          Boolean   @default(false) // 是否已签约（会员签约，非ETC申办签约）
  isActivated       Boolean   @default(false) // 是否已激活
  activatedAt       DateTime? // 激活时间
  agreementAccepted Boolean   @default(false)
  createdAt         DateTime  @default(now())
  paidAt            DateTime?
  updatedAt         DateTime  @updatedAt

  @@index([userId])
  @@index([status])
}

model Member {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id])
  productId       String
  product         MemberProduct @relation(fields: [productId], references: [id])
  status          String    @default("TRIAL") // TRIAL / ACTIVE / EXPIRED / CANCELLED / PENDING_CANCEL
  startDate       DateTime
  endDate         DateTime
  isTrial         Boolean   @default(true)
  cancelReason    String?   // USER_CANCEL / ADMIN_CANCEL / BILLING_FAILED / ETC_CANCELLED
  cancelAt        DateTime?
  warrantyEndDate DateTime? // 维保到期日期
  plateNumber     String?   // 绑定车牌
  plateColor      String?   // 车牌颜色
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  billings        BillingRecord[]

  @@index([userId])
  @@index([status])
}

model BillingRecord {
  id        String   @id @default(cuid())
  memberId  String
  member    Member   @relation(fields: [memberId], references: [id])
  amount    Float
  type      String   @default("MEMBERSHIP_FEE") // MEMBERSHIP_FEE / TOLL_FEE
  status    String   @default("PENDING") // SUCCESS / FAILED / PENDING
  remark    String?
  createdAt DateTime @default(now())

  @@index([memberId])
  @@index([type])
}

model Settlement {
  id          String   @id @default(cuid())
  type        String   // INCOME / EXPENSE
  amount      Float
  description String?
  status      String   @default("PENDING") // PENDING / COMPLETED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model UserRight {
  id              String        @id @default(cuid())
  userId          String
  rightId         String
  right           Right         @relation(fields: [rightId], references: [id])
  memberId        String        // 关联会员记录
  status          String        @default("ACTIVE") // ACTIVE / USED / EXPIRED
  totalCount      Int           @default(1)
  usedCount       Int           @default(0)
  expireAt        DateTime
  rightDisabledAt DateTime?     // 权益被禁用的时间，旧会员保留权益至会员期结束
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  usages          RightUsage[]

  @@index([userId])
  @@index([status])
}

model RightUsage {
  id          String    @id @default(cuid())
  userRightId String
  userRight   UserRight @relation(fields: [userRightId], references: [id])
  type        String    // RESCUE / REPLACE / INSURANCE
  description String?
  operator    String?
  createdAt   DateTime  @default(now())

  @@index([userRightId])
}

model SystemConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  category    String   @default("GENERAL") // BILLING / MEMBER / GENERAL
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
}

model BillingLog {
  id        String   @id @default(cuid())
  userId    String
  memberId  String?
  type      String   // MEMBERSHIP_FEE / PER_USE_FEE
  amount    Float
  status    String   // SUCCESS / FAILED / PENDING / CAPPED
  reason    String?
  month     String   // YYYY-MM
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([month])
  @@index([status])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // TRIAL_EXPIRING / BILLING_REMINDER / BILLING_FAILED / CANCEL_CONFIRM / MEMBER_STATUS_CHANGE
  title     String
  content   String
  channel   String   // SMS / PUSH / IN_APP
  status    String   @default("PENDING") // PENDING / SENT / FAILED
  sentAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([status])
}
